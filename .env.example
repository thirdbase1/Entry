# Entry — environment variables
# Copy to .env for local dev. In production, set these in Vercel
# (Settings → Environment Variables). See DEPLOY.md for the full guide.

# ── Required to boot ─────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/entry
UPSTASH_REDIS_URL=https://your-redis.upstash.io
BETTER_AUTH_SECRET=          # openssl rand -base64 32
EVE_INTERNAL_JWT_SECRET=     # openssl rand -hex 32

# ── BYOK (bring-your-own-key model providers) ────────────────────
# Encrypts user-supplied API keys (AES-256-GCM) before storing them in the
# DB. Required only if you want the BYOK settings page to work — omitting
# it means any attempt to save a provider WITH an API key will fail with a
# clear "BYOK_ENCRYPTION_KEY is not set" error (key-less endpoints still work).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
BYOK_ENCRYPTION_KEY=

# ── Optional — features degrade gracefully without these ─────────
AI_GATEWAY_API_KEY=          # local dev only; Vercel injects VERCEL_OIDC_TOKEN in prod
PARALLEL_API_KEY=            # web search tool; no-ops without it
BROWSER_USE_API_KEY=         # browser_use tool, lane 1 (browser-use.com) — required for the tool to work at all
BROWSER_USE_API_KEY_2=       # browser_use tool, lane 2 (same provider, 2nd account/key) — optional, enables a 2nd parallel session
STEEL_API_KEY=               # browser_use tool, lane 3 (steel.dev, raw CDP browser) — optional, enables a 3rd parallel session
SENDBYTE_API_KEY=            # magic-link email; app works without it
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Auto-provisioned by Vercel — no action needed ─────────────────
# BLOB_READ_WRITE_TOKEN, VERCEL_OIDC_TOKEN, VERCEL_PROJECT_PRODUCTION_URL,
# VERCEL_REGION are injected automatically when deployed on Vercel.
