generator client {
  // Prisma ORM v7: "prisma-client-js" (Rust engine) is removed; "prisma-client"
  // is the new Rust-free TS/WASM client. Confirmed via prisma.io/docs/guides/upgrade-prisma-orm/v7.
  // `output` is now required (no more implicit node_modules generation).
  provider        = "prisma-client"
  output          = "../src/generated"
  // "metrics" preview feature was removed in v7 (deprecated since 6.14, gone in 7.0) — dropped.
  // relationJoins/nativeDistinct/postgresqlExtensions kept; `prisma generate` validates these for real below.
  previewFeatures = ["relationJoins", "nativeDistinct", "postgresqlExtensions"]
}

datasource db {
  // Prisma ORM v7: `url` in schema.prisma is REJECTED now (P1012, confirmed by
  // actually running `prisma generate`, not just docs prose) — connection URL
  // now lives solely in prisma.config.ts, and the PrismaClient constructor
  // takes a driver `adapter` instead.
  provider   = "postgresql"
  extensions = [pgvector(map: "vector")]
}

model User {
  id            String    @id @default(uuid()) @db.VarChar
  name          String    @db.VarChar
  email         String    @unique @db.VarChar
  emailVerified Boolean   @default(false) @map("email_verified") @db.Boolean
  image         String?   @map("avatar_url") @db.VarChar
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  /// Indicate whether the user finished the signup progress.
  registered    Boolean   @default(true)
  disabled      Boolean   @default(false)

  accounts        Account[]
  sessions        Session[]
  features        UserFeature[]
  aiSessions      AiSession[]
  appConfigs      AppConfig[]
  createdAiJobs   AiJobs[]           @relation("createdAiJobs")
  settings        UserSettings?
  AiUserFiles     AiUserFiles[]
  AiUserDocs      AiUserDocs[]
  eveChatSessions EveChatSession[]
  modelProviders UserModelProvider[]
  credentials     UserCredential[]
  agentSkills     AgentSkill[]

  @@index([email])
  @@map("users")
}

model Account {
  id                    String    @id @default(uuid()) @db.VarChar
  userId                String    @map("user_id") @db.VarChar
  providerId            String    @map("provider_id") @db.VarChar
  accountId             String    @map("account_id") @db.VarChar
  refreshToken          String?   @map("refresh_token") @db.Text
  accessToken           String?   @map("access_token") @db.Text
  idToken               String?   @map("id_token") @db.Text
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at") @db.Timestamptz(3)
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at") @db.Timestamptz(3)
  scope                 String?   @db.Text
  expiresAt             DateTime? @map("expires_at") @db.Timestamptz(3)
  password              String?   @db.VarChar
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt             DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_accounts")
}

model Session {
  id        String   @id @default(uuid()) @db.VarChar
  expiresAt DateTime @map("expires_at") @db.Timestamptz(3)
  token     String   @unique @db.VarChar
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)
  ipAddress String?  @map("ip_address") @db.VarChar
  userAgent String?  @map("user_agent") @db.Text
  userId    String   @map("user_id") @db.VarChar

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model Verification {
  id         String   @id @default(uuid()) @db.VarChar
  identifier String   @db.VarChar
  value      String   @db.Text
  expiresAt  DateTime @map("expires_at") @db.Timestamptz(3)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@map("verifications")
}

model Feature {
  id        Int      @id @default(autoincrement())
  name      String   @map("feature") @db.VarChar
  configs   Json     @default("{}") @db.Json
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)

  userFeatures UserFeature[]

  @@unique([name])
  @@map("features")
}

model UserFeature {
  id        Int       @id @default(autoincrement())
  userId    String    @map("user_id") @db.VarChar
  featureId Int       @map("feature_id") @db.Integer
  // it should be typed as `optional` in the codebase, but we would keep all values exists during data migration.
  // so it's safe to assert it a non-null value.
  name      String    @default("") @map("name") @db.VarChar
  // a little redundant, but fast the queries
  type      Int       @default(0) @map("type") @db.Integer
  reason    String    @db.VarChar
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  expiredAt DateTime? @map("expired_at") @db.Timestamptz(3)
  activated Boolean   @default(false)

  feature Feature @relation(fields: [featureId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([name])
  @@index([featureId])
  @@map("user_features")
}

model Wishlist {
  email     String   @id @db.VarChar
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([email])
  @@map("wishlists")
}

enum AiPromptRole {
  system
  assistant
  user
}

model AiPromptMessage {
  promptId    Int          @map("prompt_id") @db.Integer
  // if a group of prompts contains multiple sentences, idx specifies the order of each sentence
  idx         Int          @db.Integer
  // system/assistant/user
  role        AiPromptRole
  // prompt content
  content     String       @db.Text
  attachments Json?        @db.Json
  params      Json?        @db.Json
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)

  prompt AiPrompt @relation(fields: [promptId], references: [id], onDelete: Cascade)

  @@unique([promptId, idx])
  @@map("ai_prompts_messages")
}

model AiPrompt {
  id             Int      @id @default(autoincrement()) @db.Integer
  name           String   @unique @db.VarChar(32)
  // an mark identifying which view to use to display the session
  // it is only used in the frontend and does not affect the backend
  action         String?  @db.VarChar
  model          String   @db.VarChar
  optionalModels String[] @default([]) @map("optional_models") @db.VarChar
  config         Json?    @db.Json
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime @default(now()) @map("updated_at") @db.Timestamptz(3)
  // whether the prompt is modified by the admin panel
  modified       Boolean  @default(false)

  messages AiPromptMessage[]
  sessions AiSession[]

  @@map("ai_prompts_metadata")
}

model AiSessionMessage {
  id            String       @id @default(uuid()) @db.VarChar
  sessionId     String       @map("session_id") @db.VarChar
  role          AiPromptRole
  content       String       @db.Text
  streamObjects Json?        @db.Json
  attachments   Json?        @db.Json
  params        Json?        @db.Json
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt     DateTime     @updatedAt @map("updated_at") @db.Timestamptz(3)

  session AiSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("ai_sessions_messages")
}

model AiSession {
  id           String    @id @default(uuid()) @db.VarChar
  userId       String    @map("user_id") @db.VarChar
  promptName   String    @map("prompt_name") @db.VarChar(32)
  promptAction String?   @default("") @map("prompt_action") @db.VarChar(32)
  pinned       Boolean   @default(false)
  title        String?   @db.VarChar
  messageCost  Int       @default(0)
  tokenCost    Int       @default(0)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(3)

  // the document id, if the session is created from a document
  docId    String? @map("doc_id") @db.VarChar
  // client custom metadata
  metadata String  @db.VarChar

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  prompt   AiPrompt  @relation(fields: [promptName], references: [name], onDelete: Cascade)
  messages AiSessionMessage[]
  // context/chatEmbedding intentionally NOT here — real eve-backed chats use
  // EveChatSession (see its model comment), and both AiContext.session and
  // AiUserChatEmbedding.session point there instead of this legacy model.

  @@index([promptName])
  @@index([userId])
  @@map("ai_sessions_metadata")
}

model AiContext {
  id        String @id @default(uuid()) @db.VarChar
  sessionId String @map("session_id") @db.VarChar
  config    Json   @db.Json

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  embeddings AiContextEmbedding[]
  // Same FK-target bug class as AiUserChatEmbedding (see EveChatSession's
  // comment): a context is attached to a live chat session, and real chats
  // are eve-backed, so this must point at EveChatSession, not the legacy
  // AiSession (which no real session row ever populates).
  session    EveChatSession       @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("ai_contexts")
}

model AiContextEmbedding {
  id        String                      @id @default(uuid()) @db.VarChar
  contextId String                      @map("context_id") @db.VarChar
  fileId    String                      @map("file_id") @db.VarChar
  // a file can be divided into multiple chunks and embedded separately.
  chunk     Int                         @db.Integer
  content   String                      @db.VarChar
  embedding Unsupported("vector(1024)")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  context AiContext @relation(fields: [contextId], references: [id], onDelete: Cascade)

  @@unique([contextId, fileId, chunk])
  @@index([embedding], map: "ai_context_embeddings_idx")
  @@map("ai_context_embeddings")
}

model AiUserChatEmbedding {
  userId    String                      @map("user_id") @db.VarChar
  sessionId String                      @map("session_id") @db.VarChar
  // a document can be divided into multiple chunks and embedded separately.
  chunk     Int                         @db.Integer
  content   String                      @db.VarChar
  embedding Unsupported("vector(1024)")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  // Points at EveChatSession, NOT the legacy AiSession — real chat sessions
  // in this port are eve-backed (id = eve's own sessionId), so embedding a
  // "chat" means embedding an EveChatSession's persisted event-log snapshot.
  // (Originally pointed at AiSession in the 1:1 schema port; corrected once
  // the embedding pipeline actually needed to read real chat content and
  // that FK proved unsatisfiable for any session created through the new
  // eve-backed chat flow.)
  session EveChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@id([userId, sessionId, chunk])
  @@index([embedding], map: "ai_user_chat_embeddings_idx")
  @@map("ai_user_chat_embeddings")
}

model AiUserDocs {
  docId     String @default(uuid()) @map("doc_id") @db.VarChar
  userId    String @map("user_id") @db.VarChar
  // always create from exists session
  sessionId String @map("session_id") @db.VarChar
  title     String @db.VarChar
  content   String @db.VarChar

  // client custom metadata
  metadata String @db.VarChar

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  embeddings AiUserDocEmbedding[]

  @@id([userId, docId])
  @@map("ai_user_docs")
}

model AiUserDocEmbedding {
  userId    String                      @map("user_id") @db.VarChar
  docId     String                      @map("doc_id") @db.VarChar
  // a document can be divided into multiple chunks and embedded separately.
  chunk     Int                         @db.Integer
  content   String                      @db.VarChar
  embedding Unsupported("vector(1024)")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  doc AiUserDocs @relation(fields: [userId, docId], references: [userId, docId], onDelete: Cascade)

  @@id([userId, docId, chunk])
  @@index([embedding], map: "ai_user_doc_embeddings_idx")
  @@map("ai_user_doc_embeddings")
}

model AiUserFiles {
  userId   String @map("user_id") @db.VarChar
  fileId   String @map("file_id") @db.VarChar
  blobId   String @default("") @map("blob_id") @db.VarChar
  fileName String @map("file_name") @db.VarChar
  mimeType String @map("mime_type") @db.VarChar
  size     Int    @db.Integer

  // client custom metadata
  metadata String @db.VarChar

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  embeddings AiUserFileEmbedding[]

  @@id([userId, fileId])
  @@map("ai_user_files")
}

model AiUserFileEmbedding {
  userId    String                      @map("user_id") @db.VarChar
  fileId    String                      @map("file_id") @db.VarChar
  // a file can be divided into multiple chunks and embedded separately.
  chunk     Int                         @db.Integer
  content   String                      @db.VarChar
  embedding Unsupported("vector(1024)")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  file AiUserFiles @relation(fields: [userId, fileId], references: [userId, fileId], onDelete: Cascade)

  @@id([userId, fileId, chunk])
  @@index([embedding], map: "ai_user_file_embeddings_idx")
  @@map("ai_user_file_embeddings")
}

enum AiJobStatus {
  pending
  running
  finished
  claimed
  failed
}

enum AiJobType {
  transcription
}

model AiJobs {
  id        String      @id @default(uuid()) @db.VarChar
  blobId    String      @map("blob_id") @db.VarChar
  createdBy String?     @map("created_by") @db.VarChar
  // job type, like "transcription"
  type      AiJobType
  status    AiJobStatus @default(pending)
  // job result
  payload   Json        @db.Json

  startedAt  DateTime  @default(now()) @map("started_at") @db.Timestamptz(3)
  finishedAt DateTime? @map("finished_at") @db.Timestamptz(3)

  // will delete creator record if creator's account is deleted
  createdByUser User? @relation(name: "createdAiJobs", fields: [createdBy], references: [id], onDelete: SetNull)

  @@unique([createdBy, blobId])
  @@map("ai_jobs")
}

model DataMigration {
  id         String    @id @default(uuid()) @db.VarChar
  name       String    @unique @db.VarChar
  startedAt  DateTime  @default(now()) @map("started_at") @db.Timestamptz(3)
  finishedAt DateTime? @map("finished_at") @db.Timestamptz(3)

  @@map("_data_migrations")
}

enum RuntimeConfigType {
  String
  Number
  Boolean
  Object
  Array
}

model AppConfig {
  id            String   @id @db.VarChar
  value         Json     @db.JsonB
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)
  lastUpdatedBy String?  @map("last_updated_by") @db.VarChar

  lastUpdatedByUser User? @relation(fields: [lastUpdatedBy], references: [id], onDelete: SetNull)

  @@map("app_configs")
}

/// BYOK (bring-your-own-key) provider connections. One connection =
/// one base URL + optional API key + a compatibility mode (which AI SDK
/// client shape to talk with). A connection can expose many models
/// (UserModelProviderModel below) — the "fetch models" action calls the
/// connection's own discovery endpoint and upserts rows there; each model
/// is individually toggle-able on/off for the chat model selector.
enum ByokCompatibility {
  OPENAI // OpenAI-compatible chat completions API — covers the vast majority of providers (Groq, Together, Fireworks, OpenRouter, DeepInfra, Mistral, xAI, local vLLM/LM Studio/Ollama, etc.)
  ANTHROPIC // Anthropic Messages API shape
  GOOGLE // Google Generative Language API shape
  OPENAI_RESPONSES // OpenAI *Responses* API shape (input/output items, not messages/choices) -- distinct from OPENAI's Chat Completions shape above. Covers aggregators that proxy models behind this newer OpenAI API style with a per-model-family base path, e.g. Kie.ai's `https://api.kie.ai/<family>/v1` (grok, gpt, gemini, claude, ...) each serving `POST {base}/responses`.
}

model UserModelProvider {
  id              String            @id @default(uuid()) @db.VarChar
  userId          String            @map("user_id") @db.VarChar
  label           String            @db.VarChar // user-facing name, e.g. "My Groq key"
  compatibility   ByokCompatibility @default(OPENAI)
  baseUrl         String            @map("base_url") @db.VarChar
  encryptedApiKey String?           @map("encrypted_api_key") @db.Text // null for key-less endpoints (e.g. local Ollama)
  lastFetchedAt   DateTime?         @map("last_fetched_at") @db.Timestamptz(3)
  lastError       String?           @map("last_error") @db.VarChar
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime          @updatedAt @map("updated_at") @db.Timestamptz(3)

  user   User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  models UserModelProviderModel[]

  @@index([userId])
  @@map("user_model_providers")
}

model UserModelProviderModel {
  id         String   @id @default(uuid()) @db.VarChar
  providerId String   @map("provider_id") @db.VarChar
  modelId    String   @map("model_id") @db.VarChar // the provider's own model slug, e.g. "llama-3.3-70b-versatile"
  label      String?  @db.VarChar // optional friendly display name, defaults to modelId in the UI
  isEnabled  Boolean  @default(true) @map("is_enabled") // whether this model shows in the chat model selector
  // Manual per-model override (2026-07-11) — /api/direct/chat's
  // reasoning-capability gate (lib/direct-chat/reasoning-capability.ts)
  // only has a naming-pattern heuristic to go on for BYOK models (no
  // catalog to authoritatively ask, unlike Gateway models), so it has real
  // false negatives: a genuinely reasoning-capable model with an
  // unrecognized name silently never gets a `reasoning` value forwarded,
  // and "thinking" never shows no matter what effort level the user picks.
  // When true, this UNCONDITIONALLY overrides that heuristic to capable —
  // set from the settings page's per-model "Thinking" toggle, for exactly
  // the models where the user knows better than the naming guess.
  // Default false: does not change behavior for any model that already
  // works via the heuristic, purely an opt-in escape hatch.
  reasoningEnabled Boolean @default(false) @map("reasoning_enabled")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  // "Test connection" result (2026-07-15, settings page BYOK feature):
  // lets a user verify a saved model actually answers before relying on
  // it in chat, from a small model-picker + button on the provider card.
  // Persisted (not just component state) so the green/red result survives
  // a settings page reload instead of resetting to "untested" every visit.
  lastTestedAt  DateTime? @map("last_tested_at") @db.Timestamptz(3)
  lastTestStatus String?  @map("last_test_status") @db.VarChar // 'success' | 'error', null = never tested
  lastTestError  String?  @map("last_test_error") @db.Text

  provider UserModelProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([providerId, modelId])
  @@index([providerId])
  @@map("user_model_provider_models")
}

model UserSettings {
  userId    String   @id @map("user_id") @db.VarChar
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)
  payload   Json     @db.JsonB

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

/// Chat session index for the eve-backed chat UI (Phase 3). Decoupled from
/// the legacy AiSession/AiPrompt system (which required an AiPrompt FK —
/// a relic of the pre-eve custom prompt/session runtime). eve owns the
/// actual durable session/turn state on its own server; this table only
/// indexes sessions for the library/sidebar UI and persists a resumable
/// snapshot (event log + session cursor) so a reload can pick the
/// conversation back up via useEveAgent's initialEvents/initialSession.
model EveChatSession {
  id         String   @id @db.VarChar // the eve sessionId itself, OR (see byokModelId) a self-generated uuid for a BYOK-direct chat
  userId     String   @map("user_id") @db.VarChar
  title      String?  @db.VarChar
  collected  Boolean  @default(false)
  docId      String?  @map("doc_id") @db.VarChar
  // Non-null marks this row as a BYOK-direct chat (see apps/web/app/api/byok/chat) —
  // one that never touches eve's session runtime or Vercel AI Gateway at all, not
  // even for the top-level turn. `events` on a BYOK-direct row holds a plain
  // `{role, content}[]` message array (NOT eve's HandleMessageStreamEvent[] shape)
  // for replay into that chat's simple useChat-based UI; `cursor` stays null.
  byokModelId String? @map("byok_model_id") @db.VarChar
  // Non-null marks this row as a direct Gateway-model chat (an explicit
  // model-picker choice like "gateway:deepseek/deepseek-v4-pro") — same
  // deal as byokModelId above (bypasses eve entirely, see
  // apps/web/app/api/direct/chat), just resolved straight from the
  // Vercel AI Gateway instead of a user's own BYOK provider row. A row
  // has at most one of byokModelId / requestedModel set, never both.
  requestedModel String? @map("requested_model") @db.VarChar
  events     Json?    @db.JsonB // persisted HandleMessageStreamEvent[] snapshot (or plain messages[] for direct-chat rows)
  cursor     Json?    @db.JsonB // persisted { sessionId, continuationToken, streamIndex } (eve rows only)
  // Public-sharing schema decision (flagged in an earlier session as a real
  // gap, resolved here): the original's `/playback` route was genuinely
  // public/unauthenticated but had no persisted "may anyone view this" bit
  // to safely gate that with either. Added here rather than left unbuilt.
  // isPublic is the actual gate (checked live on every public read); the
  // token is a stable, unguessable (UUID) opaque handle so a chat's real
  // sessionId is never itself the shareable secret. Token is generated once
  // and kept even if isPublic later flips false->true again (re-sharing
  // reuses the same link, common share-link UX), but the DB-level
  // `isPublic` boolean is what actually blocks reads while off.
  isPublic   Boolean  @default(false) @map("is_public")
  shareToken String?  @unique @map("share_token") @db.VarChar
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  user          User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  chatEmbedding AiUserChatEmbedding[]
  context       AiContext[]

  @@index([userId])
  @@map("eve_chat_sessions")
}

// Persistent, queryable error log — added 2026-07-11 per explicit request
// ("log everything so we can spot error once"). Confirmed real gap:
// server-side failures were only ever `console.error`'d, and Vercel's
// `vercel logs` CLI only tails a very short live window (confirmed
// directly — a test message's log was already gone within a couple
// minutes of checking), so almost every real production error was
// effectively unrecoverable after the fact. This table is the durable
// side-channel: every catch/onError block that already logs to console
// ALSO writes one row here, fire-and-forget (a logging failure must never
// break the actual request), so any error can be queried later by userId,
// chatId, source, or time range instead of needing to catch it live.
model ErrorLog {
  id        String   @id @default(cuid())
  source    String   @db.VarChar // e.g. "direct-chat", "eve-chat", "byok-fetch-models"
  message   String   @db.Text
  stack     String?  @db.Text
  userId    String?  @map("user_id") @db.VarChar
  chatId    String?  @map("chat_id") @db.VarChar
  context   Json?    @db.JsonB // free-form extra detail (modelId, providerLabel, status code, etc.)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([source])
  @@index([userId])
  @@index([chatId])
  @@index([createdAt])
  @@map("error_logs")
}

// Encrypted secret vault (2026-07-11) — "a secure place in the sandbox
// where AI can save credentials and inject auth when it wants to use
// them." Rows are encrypted at rest with AES-256-GCM (see
// apps/agent/agent/lib/credential-vault.ts) using a server-only
// CREDENTIAL_VAULT_KEY — a DB read alone (leak, backup, admin query)
// never exposes the plaintext value. Scoped per-user; `service` is
// freeform (not an enum) specifically so the AI can save a credential for
// any service the user mentions, including ones we've never hard-coded
// support for — matches the "register more types... should be many"
// request without needing a schema change per integration.
model UserCredential {
  id             String   @id @default(uuid())
  userId         String   @map("user_id") @db.VarChar
  service        String   @db.VarChar // e.g. "github", "vercel", "stripe", "custom:acme-api"
  label          String   @default("default") @db.VarChar // distinguishes multiple creds for the same service
  encryptedValue String   @map("encrypted_value") @db.Text // base64: iv (12B) + authTag (16B) + ciphertext
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, service, label])
  @@index([userId])
  @@map("user_credentials")
}

// Self-authored agent skills (2026-07-11) — "let the model create new
// skills by itself." Deliberately the SAME shape as the static SKILL.md
// files under apps/agent/agent/skills/ (a description that tells the
// agent WHEN to reach for it, plus markdown instructions) rather than
// arbitrary stored/executed code: a skill can only ever teach the agent
// new STEPS for tools it already safely has (bash inside its own
// per-chat sandbox, browser_use, etc.), never grant a new capability —
// so this has no code-injection surface despite being fully
// agent-writable. Scoped per-user: one user's saved workflow (e.g. "how
// I like my API deployed") is never shown to another user.
model AgentSkill {
  id           String   @id @default(uuid())
  userId       String   @map("user_id") @db.VarChar
  name         String   @db.VarChar // slug, e.g. "deploy-my-fastapi-app"
  description  String   @db.Text // when the agent should reach for this
  instructions String   @db.Text // the actual how-to, markdown
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId])
  @@map("agent_skills")
}

// Browser-preview support (2026-07-11) — "put a browser preview in the
// UI, powered by the sandbox of each chat." Written by the SERVER side
// only, in two different ways depending on which chat path the row is
// for (see EveChatSession.byokModelId's comment for the same split):
//   - direct-chat/BYOK path: apps/web/app/api/chats/[sessionId]/preview's
//     route handler writes it directly, straight from `@vercel/sandbox`'s
//     own real `.domain(port)` — that path has a genuine external handle
//     on its sandbox (see lib/direct-chat/sandbox.ts's file comment).
//   - default eve path: eve's own sandbox has NO external handle outside
//     a live agent turn (confirmed against eve's own public SandboxSession
//     type — no name override, no domain()/port API) — so for this path
//     the get_preview_url TOOL itself (apps/agent/agent/lib/tool-impls/
//     get_preview_url.ts), running inside the sandbox via ctx.getSandbox(),
//     starts a localtunnel and writes the resulting URL here. This is why
//     the row is the single source of truth the UI polls, instead of the
//     UI ever trying to reach a sandbox directly.
// One row per chat (id === EveChatSession.id, both paths) — no separate
// PK/relation needed, this IS keyed 1:1 with the chat itself.
model ChatPreview {
  chatId       String   @id @map("chat_id") @db.VarChar
  url          String?  @db.VarChar
  port         Int?
  status       String   @default("stopped") @db.VarChar // starting | live | stopped | error
  errorMessage String?  @map("error_message") @db.Text
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("chat_previews")
}

// One row per chat (id === EveChatSession.id, both paths), mirrors
// ChatPreview's shape/rationale exactly. Written by the `list_files` tool
// (eve path) or computed live from the sandbox (direct/BYOK path — see
// /api/chats/[sessionId]/files) whenever the agent's sandbox file state
// might be worth showing in the chat header's "Files" tab. `treeJson` is
// a JSON-encoded array of { path, type: "file"|"dir", size? } entries,
// kept intentionally flat (not nested objects) so the frontend can build
// whatever tree shape it wants without a server-side schema change.
model ChatFileTree {
  chatId    String   @id @map("chat_id") @db.VarChar
  treeJson  String   @map("tree_json") @db.Text
  rootLabel String?  @map("root_label") @db.VarChar
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("chat_file_trees")
}

// Persists the E2B snapshot ID captured by the custom eve sandbox backend
// (apps/agent/agent/sandbox/e2b-backend.ts) during `prewarm()`. E2B has no
// "build a reusable image from a Dockerfile" concept that maps onto eve's
// arbitrary-JS `bootstrap()` hook the way Docker/Vercel Sandbox templates
// do — the closest primitive is `sandbox.createSnapshot()` (one-to-many:
// a single snapshot can spawn many new independent sandboxes). `prewarm()`
// runs in the Vercel BUILD container; `create()` runs later in the
// deployed serverless function — different processes entirely, so the
// resulting snapshotId has to be persisted somewhere both sides can reach.
// Postgres (already wired up everywhere else in this app) is the simplest
// option, rather than inventing a second storage mechanism just for this.
model SandboxTemplate {
  templateKey String   @id @map("template_key") @db.VarChar
  snapshotId  String   @map("snapshot_id") @db.VarChar
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("sandbox_templates")
}

// Added 2026-07-16 as part of migrating the direct-chat path
// (/api/direct/chat -- every BYOK and Gateway-direct-model-pick chat) off
// a standalone, never-updated `@vercel/sandbox` implementation and onto
// E2B, matching eve's own root-agent path (see
// apps/agent/agent/sandbox/e2b-backend.ts). That old Vercel-Sandbox path
// had no "get by id" persistence of its own -- @vercel/sandbox's
// `getOrCreate({ name })` resolves reuse by NAME against Vercel's own
// account-scoped index, a mechanism E2B has no equivalent for (E2B only
// supports reconnecting by an explicit sandbox id via `Sandbox.connect`).
// This table is that missing persistence layer: one row per chat, holding
// the live E2B sandboxId so the next tool call in the same chat resumes
// the SAME sandbox (same filesystem, same running dev server) instead of
// spinning up a fresh one every turn.
model ChatSandbox {
  chatId    String   @id @map("chat_id") @db.VarChar
  sandboxId String   @map("sandbox_id") @db.VarChar
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("chat_sandboxes")
}

// Custom, app-native version history (2026-07-16, explicit user request:
// "not GitHub versioning... our own custom versioning, so when agent do
// something wrong I can revert to another version"). Deliberately NOT a
// git-log/commit browser (no shas, no commit messages, no GitHub links
// in the product) -- each row is a plain-language checkpoint the agent
// writes after shipping a change, and "revert" is meant to be instant
// and fully self-service from the UI with zero agent involvement at
// click time.
//
// Under the hood each version still maps to an already-built, immutable
// Vercel deployment artifact (vercelDeploymentId) purely because that's
// the only mechanism that makes "click revert -> live in seconds, no
// rebuild" actually true; that's an implementation detail the product
// never surfaces.
model AppVersion {
  id                 String   @id @default(cuid())
  label              String   @db.VarChar(500)
  vercelDeploymentId String   @map("vercel_deployment_id") @db.VarChar
  vercelUrl          String?  @map("vercel_url") @db.VarChar
  createdAt          DateTime @default(now()) @map("created_at")

  @@map("app_versions")
}

// Custom, app-native PER-CHAT version history (2026-07-16, replaces the
// user's rejected "GitHub versioning" idea entirely -- explicit request:
// "our own internal versioning system... every time the agent modifies
// one or more files, it should automatically create a new version
// (snapshot)... a clean minimal version card... tapping opens history...
// no Compare button, only Revert, instantly restore".
//
// Scope is ONE chat's own sandbox/project (each chat already has its own
// isolated sandbox -- see ChatSandbox/ChatFileTree), NOT this repo's own
// source code (that's what AppVersion above is for, a separate, unrelated
// concept). versionNumber is sequential per chatId (1, 2, 3...), assigned
// the moment the agent finishes a turn that actually touched >=1 file --
// see packages/db/src/chat-versioning.ts for where these rows get
// written (hooked into sandboxWriteFile/sandboxAppendFile, the single
// choke point both eve's root agent and the direct/BYOK chat path share
// for every file mutation) and apps/web/app/api/chats/[id]/versions for
// how they're read/reverted.
model ChatVersion {
  id                        String   @id @default(cuid())
  chatId                    String   @map("chat_id") @db.VarChar
  versionNumber             Int      @map("version_number")
  summary                   String   @db.Text
  filesChanged               Int      @map("files_changed")
  linesAdded                Int      @map("lines_added")
  linesRemoved              Int      @map("lines_removed")
  // Set only on a version CREATED BY a revert action -- the version
  // number that was restored. Lets the chat-timeline card read "Version
  // 7 · Reverted from v1" per the user's exact spec, and lets the
  // History page skip showing a Revert button on a version that IS the
  // live head.
  revertedFromVersionNumber Int?     @map("reverted_from_version_number")
  createdAt                 DateTime @default(now()) @map("created_at")

  @@unique([chatId, versionNumber])
  @@index([chatId, createdAt])
  @@map("chat_versions")
}

// One row per file that actually changed in a given ChatVersion. Always
// stores the file's FULL new content (not just a diff) so revert never
// needs the diff to be losslessly invertible -- the unified diff shown
// in the UI is derived on read by diffing THIS content against whatever
// the same `path` last stored in the highest versionNumber < this one
// for the same chatId (see findPreviousContent in chat-versioning.ts).
// chatId + versionNumber are denormalized from ChatVersion (not just a
// versionId FK) specifically so the revert query below can be a single
// indexed `DISTINCT ON (path)` scan with no join.
model ChatVersionFile {
  id            String  @id @default(cuid())
  chatId        String  @map("chat_id") @db.VarChar
  versionId     String  @map("version_id")
  versionNumber Int     @map("version_number")
  path          String  @db.VarChar
  changeType    String  @map("change_type") @db.VarChar // 'added' | 'modified' | 'deleted'
  content       String? @db.Text // full new file content; null when changeType is 'deleted'
  linesAdded    Int     @map("lines_added")
  linesRemoved  Int     @map("lines_removed")

  @@index([chatId, path, versionNumber])
  @@index([versionId])
  @@map("chat_version_files")
}
