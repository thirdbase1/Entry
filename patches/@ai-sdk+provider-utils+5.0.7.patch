+++ b/node_modules/@ai-sdk/provider-utils/src/streaming-tool-call-tracker.ts
@@ -119,8 +119,24 @@ export class StreamingToolCallTracker<
    * flush handler to ensure all tool calls are properly completed.
    */
   flush(): void {
+    // Defensive against sparse holes in `this.toolCalls`: some
+    // OpenAI-compatible upstreams (confirmed with a BYOK Qwen-family model
+    // via an aggregator) emit tool-call deltas whose `index` is NOT a
+    // contiguous 0..n sequence (e.g. it skips a number). `processNewToolCall`
+    // assigns via `this.toolCalls[index] = {...}`, so a skipped index leaves
+    // a genuine array hole. `for...of` over a sparse array does NOT skip
+    // holes the way `forEach`/`map` do -- it yields `undefined` for them --
+    // so the original `toolCall.hasFinished` read threw
+    // "TypeError: Cannot read properties of undefined (reading 'hasFinished')"
+    // the instant this flush() ran (end of the tool-call streaming portion of
+    // a step). That throw happened inside a low-level transform stream's
+    // flush(), below every one of the AI SDK's own onError/onStepFinish
+    // hooks, so it surfaced only as a bare "failed to pipe response" at the
+    // Next.js response-piping layer with the whole turn silently dying --
+    // no onError, no visible error, no persisted assistant text. Exactly the
+    // "agent stops instantly after a tool call, no error shown" report.
     for (const toolCall of this.toolCalls) {
-      if (!toolCall.hasFinished) {
+      if (toolCall && !toolCall.hasFinished) {
         this.finishToolCall(toolCall);
       }
     }
