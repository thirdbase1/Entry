legacy-peer-deps=true

# Vercel sets NODE_ENV=production for all builds (documented Vercel build
# behavior), and npm's own `omit` config defaults to "dev" whenever
# NODE_ENV=production (confirmed empirically: `NODE_ENV=production npm
# config get omit` -> "dev", vs empty otherwise) -- meaning a plain
# `npm install` on Vercel silently skips devDependencies entirely. That
# broke the postinstall script's `patch-package` step in production
# (patch-package is a devDependency, needed at install time to apply
# patches/eve+0.20.0.patch and the blocksuite-icons patch) with a real
# "npm error npx canceled due to missing packages" failure on a live
# deploy. This line forces devDependencies to always install regardless
# of NODE_ENV, matching local/dev behavior exactly.
omit=
